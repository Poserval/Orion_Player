##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then to run this script, type that shell name before the whole
#       command line, like:
#
#           ksh gradle
#
#       Busybox and similar reduced shells will NOT work, because this script
#       requires all of these POSIX shell features:
#         * functions;
#         * expansions «$var», «${var}», «${var:-default}», «${var+placeholder}»;
#         * compound commands having a testable exit status, especially «case»;
#         * various built-in commands including «command», «set», and «ulimit».
#
#   Important for patching:
#
#   (2) This script targets any POSIX shell, so it avoids extensions provided
#       by Bash, Ksh, etc; in particular arrays are avoided.
#
#       The "traditional" practice of packing multiple parameters into a
#       space-separated string is a well documented source of bugs and security
#       problems, so this is (mostly) avoided, by progressively accumulating
#       options in "$@", and eventually passing that to Java.
#
#       Where the inherited environment variables (DEFAULT_JVM_OPTS, JAVA_OPTS,
#       and GRADLE_OPTS) rely on word-splitting, this is performed explicitly;
#       see the in-line comments for details.
#
#       There are tweaks for specific operating systems such as AIX, CygWin,
#       Darwin, MinGW, and NonStop.
#
#   (3) This script is generated from the Groovy template
#       https://github.com/gradle/gradle/blob/master/subprojects/launcher/src/main/resources/org/gradle/launcher/bin/unix/start.sh
#       within the Gradle project.
#
#       You can find Gradle at https://github.com/gradle/gradle/.
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}  # leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in                #(
  CYGWIN* )         cygwin=true  ;; #(
  Darwin* )         darwin=true  ;; #(
  MSYS* | MINGW* )  msys=true    ;; #(
  NONSTOP* )        nonstop=true ;;
esac

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in #(
      max*)
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order to eventually pass to $JAVACMD.
# * java_vm_parameters: the java VM options
# * java_parameters: the classpath and main class parameters
# * cmdline_parameters: the command line parameters from this script

# Collect all arguments for the java command;
#   $1 $2 $3 _must_ be placed *before* any '--' separated items, because '--' items
#   are appended to the end of the command line if the '--' option is present.
#
#   A '--' option indicates the end of the arguments for the command line parser
#   (and also indicates the start of the 'cmdline_parameters' group).

# The user can specify JVM args, --args, and --java-args in a custom property
# in gradle.properties; gradle.properties can be serialized across invocations.
# Unset this if it's present.
unset ORG_GRADLE_PROJECT_javaHome

# We use 'cmdline_parameters' and 'java_parameters' to avoid polluting the JVM
# args with 'cmdline_parameters' (since 'java_parameters' is the classpath and
# main class, which is really part of the cmdline, but splitting this way
# prevents duplication of '--args' et al between the two groups).

# A POSIX variable wrapper required to support running the script with a
# trailing '--args' option.
preArgs=true
while [ $# -gt 0 ]; do
    case $1 in
        --java-home)            # Set the Java home.
            ORG_GRADLE_PROJECT_javaHome="$2"
            shift; shift;;
        --javacmd)               # Set the Java command.
            JAVACMD="$2"
            shift; shift;;
        --add-opens)             # Pass java add-opens option.
            java_vm_parameters="$java_vm_parameters --add-opens $2"
            shift; shift;;
        --add-exports)           # Pass java add-exports option.
            java_vm_parameters="$java_vm_parameters --add-exports $2"
            shift; shift;;
        --patch-module)          # Pass java patch-module option.
            java_vm_parameters="$java_vm_parameters --patch-module $2"
            shift; shift;;
        --enable-preview)        # Pass java enable-preview option.
            java_vm_parameters="$java_vm_parameters --enable-preview"
            shift;;
        --enable-native-access)  # Pass java enable-native-access option.
            java_vm_parameters="$java_vm_parameters --enable-native-access"
            shift;;
        -D*)
            java_vm_parameters="$java_vm_parameters $1"
            shift;;
        *)
            if $preArgs; then
                # If this is a pre-argument, we can start accumulating now.
                preArgs=false
                # Accumulate all arguments after the first 'pre' argument.
                set -- "$@" "$1"
            else
                # We are already in the parameter list proper, so just append.
                set -- "$@" "$1"
            fi
            shift;;
    esac
done

# Collect all arguments for the java command;
#   $@ is the cmdline_parameters (the first 'pre' argument).
eval set -- "$java_vm_parameters" '"$@"'

# By default we first collect all java_parameters (which is everything up to an
# executable which may have its own argument parsing). Then we later append the
# cmdline_parameters to it if necessary.

java_parameters=""
for arg do
    case $arg in
        --add-opens)                 # Pass java add-opens option.
            java_parameters="$java_parameters --add-opens $2"
            shift; shift;;
        --add-exports)               # Pass java add-exports option.
            java_parameters="$java_parameters --add-exports $2"
            shift; shift;;
        --patch-module)              # Pass java patch-module option.
            java_parameters="$java_parameters --patch-module $2"
            shift; shift;;
        --enable-preview)            # Pass java enable-preview option.
            java_parameters="$java_parameters --enable-preview"
            shift;;
        --enable-native-access)      # Pass java enable-native-access option.
            java_parameters="$java_parameters --enable-native-access"
            shift;;
        -D*)                         # Pass java vm option.
            java_parameters="$java_parameters $arg"
            shift;;
        *)
            # Not a Java parameter; we must have reached the main class.
            # But we allow multiple main classes, but they must be separated by '--'.
            # Stop processing Java parameters when we reach the main class.
            break;;
    esac
done

# Now we can collect the cmdline_parameters.
cmdline_parameters=""
for arg do
    cmdline_parameters="$cmdline_parameters $arg"
done

# Decide if we need to use --main or not.
if [ -n "$cmdline_parameters" ]; then
    # Convert to an array and remove the leading space.
    set -- $cmdline_parameters
    # If the first parameter is --args or --java-args, then we are using the
    # Gradle-specific argument passing mechanism.
    case $1 in
        --args)                      # Gradle-specific: --args <args>
            shift
            set -- "$@" "$1"
            ;;
        --java-args)                 # Gradle-specific: --java-args <args>
            shift
            set -- "$@" "$1"
            ;;
        *)
            # Not a Gradle-specific argument, so we use the main class.
            set -- "$@"
            ;;
    esac
fi

# Determine the Java command to use to start the JVM, stacking the VM and Java args.
exec "$JAVACMD" $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS $java_vm_parameters -classpath "$APP_HOME/lib/gradle-launcher-8.10.jar" org.gradle.launcher.GradleMain "$@"
